# Copy this file to .env and paste your real values there.
# Never commit .env.

DEBUG=false
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require

# Optional: use MongoDB for raw telemetry / event payloads.
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/?appName=Cluster0
MONGODB_DATABASE=bankguard

JWT_SECRET=change-this-for-demo
